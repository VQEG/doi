    <xsd:sequence minOccurs="0" maxOccurs="unbounded">
      <xsd:any processContents="lax" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:element name="math" type="math-type"/>
